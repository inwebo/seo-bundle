{
    "name": "inwebo/seo-bundle",
    "description": "A lightweight Symfony bundle to manage SEO metadata and breadcrumbs.",
    "keywords": ["symfony", "bundle", "seo", "metadata", "breadcrumbs"],
    "homepage": "https://github.com/inwebo/seo-bundle",
    "type": "symfony-bundle",
    "version": "1.0.0",
    "require": {
        "php": ">=8.1",
        "symfony/routing": "*",
        "symfony/http-kernel": "*",
        "doctrine/orm": "^3.0",
        "twig/twig": "^3.21",
        "symfony/event-dispatcher": "*",
        "symfony/framework-bundle": "*",
        "symfony/uid": "*",
        "doctrine/doctrine-bundle": "^3.0|^2.7",
        "symfony/console": "*",
        "symfony/twig-bundle": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.4",
        "friendsofphp/php-cs-fixer": "^3.88",
        "phpstan/phpstan": "^2.1",
        "symfony/yaml": "*",
        "symfony/browser-kit": "*"
    },
    "license": "GPL-3.0-or-later",
    "autoload": {
        "psr-4": {
            "Inwebo\\SeoBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Inwebo\\SeoBundle\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "inwebo",
            "email": "github@inwebo.net"
        }
    ],
    "extra": {
      "symfony": {
        "allow-contrib": false,
        "require": "8.*"
      }
    },
    "minimum-stability": "stable",
    "scripts": {
      "php-cs-fixer": "vendor/bin/php-cs-fixer --allow-risky=yes fix",
      "phpunit": "vendor/bin/phpunit --testdox --colors=always --display-all-issues",
      "phpstan": "vendor/bin/phpstan analyse src -c phpstan.neon"
    }
}
